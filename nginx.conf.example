# Map incoming Upgrade headers to Connection headers dynamically
# If $http_upgrade is set (WebSocket), Connection is set to 'upgrade'
# If $http_upgrade is empty (Normal HTTP), Connection is cleared for keepalive
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      "";
}

upstream api_backend {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    server_name api.abhaybisht.com;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Increase read/write timeouts so the terminal WebSocket doesn't disconnect
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;

        proxy_pass http://api_backend;
    }
}
