{
  "name": "api21",
  "version": "1.0.0",
  "description": "Nuxt 4 + Nitro + Bun — SSR portfolio + API with Knex (PostgreSQL) and Redis",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start:prod": "bun .output/server/index.mjs",
    "start": "pm2 delete api21 ; pm2 start ecosystem.config.js",
    "prestart": "bun db:migrate",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "db:migrate": "bun --bun x knex migrate:latest",
    "db:rollback": "bun --bun x knex migrate:rollback",
    "db:make-migration": "bun --bun x knex migrate:make",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test": "bun run test:unit && bun run test:e2e",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs api21",
    "pm2:delete": "pm2 delete api21"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "knex": "^3.2.10",
    "nuxt": "^4.4.8",
    "pg": "^8.21.0",
    "redis": "^4.6.14",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.10.2",
    "pm2": "^7.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
