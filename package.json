{
  "name": "api21",
  "version": "1.0.0",
  "description": "Express + TypeScript + Bun API with MVC, Mongoose, Redis",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "console": "bun src/console.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.0",
    "node-cron": "^4.2.1",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.5"
  }
}
